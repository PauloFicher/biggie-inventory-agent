# Biggie (Grupo Azeta) - Variables de entorno
# Copiar a .env.local y reemplazar con valores reales

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (proveedor principal de LLM)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# DeepSeek (proveedor alternativo, menor costo)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000
LLM_PROVIDER=openai
# LLM_PROVIDER=deepseek  (usar DeepSeek en vez de OpenAI)
